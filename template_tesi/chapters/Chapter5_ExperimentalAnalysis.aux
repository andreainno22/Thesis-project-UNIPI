\citation{Cheng2024yoloworld}
\newlabel{fig:p3-d2-fp-blind-ref}{{5.5a}{60}{Reference (normal)}{figure.caption.84}{}}
\newlabel{sub@fig:p3-d2-fp-blind-ref}{{a}{60}{Reference (normal)}{figure.caption.84}{}}
\newlabel{fig:p3-d2-fp-blind-heatmap}{{5.5b}{60}{Anomaly heatmap}{figure.caption.84}{}}
\newlabel{sub@fig:p3-d2-fp-blind-heatmap}{{b}{60}{Anomaly heatmap}{figure.caption.84}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.5}{\ignorespaces Hard-negative false positive (worst case, score $3.873$) on a glass door. In the reference the external rolling shutter is up and the glass shows the courtyard outside; in the test frame the shutter is lowered, so the view through the panel changes completely. The background variation is too large for the fixed-camera assumption: the entire glazed area exceeds the anomaly threshold and overlaps the door frame, producing a false detection. This is a calibration limit of the static-background assumption, not a gating failure.}}{60}{figure.caption.84}\protected@file@percent }
\newlabel{fig:p3-d2-fp-blind}{{5.5}{60}{Hard-negative false positive (worst case, score $3.873$) on a glass door. In the reference the external rolling shutter is up and the glass shows the courtyard outside; in the test frame the shutter is lowered, so the view through the panel changes completely. The background variation is too large for the fixed-camera assumption: the entire glazed area exceeds the anomaly threshold and overlaps the door frame, producing a false detection. This is a calibration limit of the static-background assumption, not a gating failure}{figure.caption.84}{}}
